        "id": "Q97hjry3K0NO"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "tokenized_datasets = load_from_disk(\"./dataset/tokenized_datasets\")"
